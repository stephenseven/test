---
// src/components/ExchangeRate.astro
// 注意：这里不需要 PHP，Astro 的前端代码直接写在 <script> 标签里
---

<div class="rate-card">
  <h2>实时汇率查询</h2>
  
  <div id="loading">正在加载汇率数据...</div>
  
  <div id="result" style="display: none;">
    <p>1 美元 ≈ <span id="usd-price" class="price">--</span> 人民币</p>
    <p>1 欧元 ≈ <span id="eur-price" class="price">--</span> 人民币</p>
    <p class="time">数据时间: <span id="update-time"></span></p>
  </div>

  <button id="refresh-btn">刷新汇率</button>
</div>

<style>
  .rate-card { border: 1px solid #ddd; padding: 20px; border-radius: 8px; max-width: 400px; margin: 20px auto; font-family: sans-serif; }
  .price { color: #d9534f; font-weight: bold; font-size: 1.2em; }
  button { cursor: pointer; padding: 8px 16px; background: #007bff; color: white; border: none; border-radius: 4px; }
  button:hover { background: #0056b3; }
</style>

<script>
  // 你的 API 密钥和地址
  const API_URL = 'https://smkjzgyhss.market.alicloudapi.com/exchange_rate/realtime?code=USD,EUR';
  const API_KEY = '39cb76a2af6e4bf288742eb934f6dc4e'; // 你的密钥

  async function fetchRates() {
    const loadingEl = document.getElementById('loading');
    const resultEl = document.getElementById('result');
    const usdEl = document.getElementById('usd-price');
    const eurEl = document.getElementById('eur-price');
    const timeEl = document.getElementById('update-time');

    try {
      // 显示加载状态
      loadingEl.style.display = 'block';
      resultEl.style.display = 'none';

      // 发起请求
      const response = await fetch(API_URL, {
        method: 'GET',
        headers: {
          'Authorization': 'APPCODE ' + API_KEY
        }
      });

      if (!response.ok) throw new Error('网络响应错误');

      const data = await response.json();

      // 解析数据 (根据你的 API 返回结构调整)
      if (data.data && data.data.list) {
        const rates = data.data.list;
        
        // 找到美元和欧元的数据
        const usd = rates.find(item => item.code === 'USD');
        const eur = rates.find(item => item.code === 'EUR');

        if (usd) {
          // 假设 hui_in 是 100外币兑人民币，除以100并保留2位小数
          usdEl.innerText = (usd.hui_in / 100).toFixed(2);
        }
        
        if (eur) {
          eurEl.innerText = (eur.hui_in / 100).toFixed(2);
        }

        // 更新时间
        timeEl.innerText = new Date().toLocaleString();
        
        // 显示结果
        loadingEl.style.display = 'none';
        resultEl.style.display = 'block';
      }

    } catch (error) {
      console.error('获取汇率失败:', error);
      loadingEl.innerText = '加载失败，请稍后重试';
    }
  }

  // 页面加载时执行
  document.addEventListener('DOMContentLoaded', fetchRates);
  
  // 绑定刷新按钮
  document.getElementById('refresh-btn').addEventListener('click', fetchRates);
</script>